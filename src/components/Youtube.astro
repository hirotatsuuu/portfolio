---
import { ja } from '../data/ja.js';
import { en } from '../data/en.js';
import { snsLinks } from '../data/sns.js';

const youtubeLink = snsLinks.find(link => link.name === "YouTube");
---

<section class="section" id="youtube">
  <div class="container">
    <h2 class="section-title">YouTube</h2>
    
    <div class="video-wrapper">
      <div class="video-container">
        <iframe 
          src="https://www.youtube.com/embed/videoseries?list=PLs9JLAzb3cG7CFuKZGlXtEpEvlJ9PZwzN&modestbranding=1&rel=0" 
          title="YouTube video player" 
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen>
        </iframe>
      </div>
    </div>

    <div class="content-area">
      <div class="lang-ja"><p>{ja.youtube.desc}</p></div>
      <div class="lang-en"><p>{en.youtube.desc}</p></div>

      {youtubeLink && (
        <a href={youtubeLink.url} target="_blank" class="youtube-btn">
          <span class="lang-ja">{ja.youtube.btn}</span>
          <span class="lang-en">{en.youtube.btn}</span>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .video-wrapper {
    width: 100%;
    max-width: 1000px; /* 動画の最大幅を広げました */
    margin: 0 auto 40px auto;
  }

  .video-container {
    position: relative;
    width: 100%;
    padding-top: 56.25%; /* 16:9 */
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 4px;
  }

  .content-area { 
    text-align: center; 
    margin-top: 20px;
  }

  .youtube-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 8px 24px;
    background: transparent;
    color: #64748b;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .youtube-btn:hover {
    background: #0f172a;
    color: #ffffff;
    border-color: #0f172a;
  }
</style>