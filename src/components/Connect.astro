---
import { ja } from '../data/ja.js';
import { en } from '../data/en.js';
import { snsLinks } from '../data/sns.js';
---

<section id="links" class="section">
  <div class="container text-center">
    <div class="lang-ja">
      <h2 class="section-title">{ja.connect.title}</h2>
      <p class="section-sub">{ja.connect.sub}</p>
    </div>
    <div class="lang-en">
      <h2 class="section-title">{en.connect.title}</h2>
      <p class="section-sub">{en.connect.sub}</p>
    </div>
    
    <div class="social-links">
      {snsLinks.map(item => (
        <a href={item.url} target="_blank" rel="noopener noreferrer" class="social-card">
          <div class="social-icon-wrapper">{item.icon}</div>
          <div class="social-info">
            <span class="social-name">{item.name}</span>
            <span class="social-user">{item.user}</span>
          </div>
          <span class="social-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .text-center { text-align: center; }
  .section-sub { color: var(--color-muted); font-size: 1.1rem; margin-top: -35px; margin-bottom: 60px; }
  .social-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; max-width: 900px; margin: 0 auto; }
  .social-card { display: flex; align-items: center; padding: 20px; background-color: #ffffff; border: 1px solid var(--color-border); border-radius: 20px; text-decoration: none; color: var(--color-dark); transition: var(--transition); }
  .social-icon-wrapper { font-size: 1.8rem; width: 50px; height: 50px; background-color: var(--color-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 16px; flex-shrink: 0; }
  .social-info { display: flex; flex-direction: column; text-align: left; }
  .social-name { font-weight: 700; font-size: 1.1rem; }
  .social-user { font-size: 0.85rem; color: var(--color-muted); font-family: var(--font-heading); }
  .social-arrow { margin-left: auto; font-size: 1.2rem; color: var(--color-border); transition: var(--transition); }
  
  .social-card:hover { transform: translateY(-4px); border-color: rgba(37, 99, 235, 0.3); box-shadow: 0 12px 20px rgba(15, 23, 42, 0.05); }
  .social-card:hover .social-icon-wrapper { background-color: var(--color-primary-light); }
  .social-card:hover .social-arrow { color: var(--color-primary); transform: translateX(4px); }
</style>