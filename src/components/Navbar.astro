---
---
<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">OTATSU</a>
    <button id="lang-toggle-btn" class="lang-switcher">
      <span class="lang-icon">🌐</span>
      <span id="lang-btn-text" data-ja="English" data-en="日本語">English</span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 70px;
    background-color: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
    z-index: 1000;
  }
  .nav-container {
    max-width: 1140px;
    height: 100%;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-weight: 800;
    font-size: 1.3rem;
    color: #ffffff;
    text-decoration: none;
  }
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 8px 16px;
    border-radius: 30px;
    color: #ffffff;
    font-family: var(--font-heading);
    cursor: pointer;
  }
</style>

<script>
  const htmlEl = document.documentElement;
  const btn = document.getElementById('lang-toggle-btn');
  const btnText = document.getElementById('lang-btn-text');
  const titleEl = document.getElementById('site-title');

  function updateLanguage(lang: string) {
    htmlEl.setAttribute('data-lang', lang);
    htmlEl.setAttribute('lang', lang);
    if (titleEl) titleEl.textContent = titleEl.getAttribute(`data-${lang}`);
    if (btnText) {
      const nextLang = lang === 'ja' ? 'en' : 'ja';
      btnText.textContent = btnText.getAttribute(`data-${nextLang}`);
    }
  }

  // 初期化
  const savedLang = localStorage.getItem('portfolio-lang') || 'ja';
  updateLanguage(savedLang);

  // イベント
  btn?.addEventListener('click', () => {
    const current = htmlEl.getAttribute('data-lang') || 'ja';
    const next = current === 'ja' ? 'en' : 'ja';
    localStorage.setItem('portfolio-lang', next);
    updateLanguage(next);
  });
</script>