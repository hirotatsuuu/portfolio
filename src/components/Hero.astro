---
import backgroundImage from '../assets/hero-bg.jpg';
import { ja } from '../data/ja.js';
import { en } from '../data/en.js';
---

<header class="hero" style={`--bg-img: url(${backgroundImage.src});`}>
  <div class="hero-overlay"></div>
  <div class="container hero-container-flex">
    <div class="hero-content lang-ja">
      <p class="hero-sub animate-fade-in">{ja.hero.sub}</p>
      <h1 class="hero-title animate-fade-in-up">{ja.hero.title}</h1>
      <p class="hero-desc animate-fade-in-up-delayed">{ja.hero.desc}</p>
      <div class="animate-fade-in-up-delayed2">
        <a href="#about" class="btn">{ja.hero.btn}</a>
      </div>
    </div>
    
    <div class="hero-content lang-en">
      <p class="hero-sub animate-fade-in">{en.hero.sub}</p>
      <h1 class="hero-title animate-fade-in-up">{en.hero.title}</h1>
      <p class="hero-desc animate-fade-in-up-delayed">{en.hero.desc}</p>
      <div class="animate-fade-in-up-delayed2">
        <a href="#about" class="btn">{en.hero.btn}</a>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    background-image: var(--bg-img);
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.5) 100%);
    z-index: 1;
  }
  .hero-container-flex {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
  }
  .hero-content {
    text-align: center;
    max-width: 800px;
    width: 100%;
  }
  .hero-sub {
    font-family: var(--font-heading);
    font-weight: 700;
    color: #60a5fa;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.95rem;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.2;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .hero-desc {
    font-size: 1.2rem;
    color: #cbd5e1;
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    font-weight: 300;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    background-color: #ffffff;
    color: var(--color-dark);
    padding: 16px 38px;
    border-radius: 50px;
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }
  .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
    background-color: var(--color-primary);
    color: #ffffff;
  }

  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .animate-fade-in { animation: fadeIn 1s ease-out forwards; }
  .animate-fade-in-up { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-fade-in-up-delayed { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards; opacity: 0; }
  .animate-fade-in-up-delayed2 { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards; opacity: 0; }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.5rem; }
    .hero-desc { font-size: 1.05rem; }
  }
</style>