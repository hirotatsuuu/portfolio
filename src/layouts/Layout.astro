---
// 全ページ共通のメタデータやフォント設定など
interface Props { title: string; }
const { title } = Astro.props;
---
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>