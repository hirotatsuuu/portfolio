---
import { ja } from '../data/ja.js';
import { en } from '../data/en.js';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="ja" data-lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title id="site-title" data-ja={ja.title} data-en={en.title}></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <Navbar />
    <slot />
  </body>
</html>

<style is:global>
  /* 全体の余白リセット（白帯対策） */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  :root {
    --font-heading: 'Plus Jakarta Sans', sans-serif;
    --color-dark: #0f172a;
    --transition: all 0.3s ease;
  }
  
  body {
    font-family: 'Noto Sans JP', sans-serif;
    background-color: var(--color-dark);
    color: #ffffff;
    -webkit-font-smoothing: antialiased;
  }
</style>